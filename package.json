{
  "name": "aegisops-autopilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "concurrently -k -n api,web \"pnpm run serve:api\" \"vite --host 0.0.0.0\"",
    "serve:api": "tsx src/server/index.ts",
    "build": "tsc -p tsconfig.json && vite build",
    "build:pages": "GITHUB_PAGES=1 pnpm run build",
    "preview": "pnpm run serve:api",
    "docker:smoke": "bash scripts/docker_smoke.sh",
    "deploy:verify": "tsx scripts/verifyAlibabaDeployment.ts",
    "deploy:verify:smoke": "tsx scripts/verifyAlibabaDeploymentSmoke.ts",
    "test": "tsx tests/orchestrator.test.ts",
    "eval": "tsx src/server/evals/runEval.ts",
    "eval:ablation": "tsx src/server/evals/runAblation.ts",
    "benchmark:stress": "tsx scripts/stressBenchmark.ts",
    "qwen:live-smoke": "tsx scripts/liveQwenSmokeProof.ts",
    "mcp:stdio": "tsx src/server/mcp/aegisopsMcp.ts",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:mcp": "tsx scripts/mcpSmoke.ts",
    "qwen:audit": "tsx scripts/qwenIntegrationAudit.ts",
    "model:ops": "tsx scripts/modelOpsReport.ts",
    "architecture:diagram": "tsx scripts/generateArchitectureDiagram.ts",
    "provenance:audit": "tsx scripts/buildProvenanceReport.ts",
    "judge:evidence": "tsx scripts/judgeEvidenceBundle.ts",
    "judge:transcript": "tsx scripts/generateJudgeTranscript.ts",
    "video:audit": "tsx scripts/videoAssetAudit.ts",
    "video:frames": "node scripts/captureDemoFrames.mjs docs/demo/frames/reel",
    "video:render": "swift scripts/imageSequenceToVideo.swift docs/demo/aegisops-demo-reel-fixed.mov 30 8.5 docs/demo/frames/reel/slide-*.png",
    "video:proof-frames": "node scripts/generateAlibabaProofFrames.mjs docs/demo/frames/alibaba-proof",
    "video:proof-render": "swift scripts/imageSequenceToVideo.swift docs/demo/alibaba-backend-proof.mov 30 7 docs/demo/frames/alibaba-proof/slide-*.png",
    "final:preflight": "tsx scripts/finalPreflight.ts",
    "submission:package": "tsx scripts/packageFinalSubmission.ts",
    "submission:validate": "tsx scripts/validateSubmissionPackages.ts",
    "submission:audit": "tsx scripts/submissionAudit.ts",
    "secret:scan": "bash scripts/secret_scan.sh",
    "release:check": "bash scripts/release_check.sh",
    "ci": "pnpm run release:check && pnpm run build:pages",
    "pages:publish": "bash scripts/publish_pages.sh",
    "video:record": "bash scripts/record_demo.sh"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
